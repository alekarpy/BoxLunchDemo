<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- ==========================================
         URL REWRITE PARA REACT SPA (BrowserRouter)
         Redirige todas las rutas al index.html para
         que React Router maneje la navegación.
         ========================================== -->
    <rewrite>
      <rules>
        <rule name="SPA React Router Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <!-- No redirigir si es un archivo físico (assets, js, css, etc.) -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <!-- No redirigir si es un directorio físico -->
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <!-- No redirigir peticiones a la API del backend -->
            <add input="{REQUEST_URI}" pattern="^/boxlunch/api/" negate="true" />
            <!-- ⚠️ CRÍTICO: No interceptar el callback de Microsoft OAuth/OIDC.
                 Sin esta regla, IIS reescribía /signin-oidc a index.html
                 causando un 404 al volver de la pantalla de login de Microsoft. -->
            <add input="{REQUEST_URI}" pattern="signin-oidc" negate="true" />
            <add input="{REQUEST_URI}" pattern="signout-callback-oidc" negate="true" />
            <add input="{REQUEST_URI}" pattern="signout-oidc" negate="true" />
          </conditions>
          <!-- Redirige al index.html dentro de /boxlunch/ -->
          <action type="Rewrite" url="/boxlunch/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Encabezados de caché: los assets llevan hash en el nombre, el index.html no se cachea -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
    </staticContent>

    <!-- Evitar que IIS devuelva su propia página de error 404 antes del rewrite -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>

  <!-- El index.html de la SPA nunca debe cachearse en el navegador -->
  <location path="index.html">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
    </system.webServer>
  </location>

</configuration>
